# Notification Service — Environment Configuration
# Copy to .env for local development. NEVER commit .env to git.
# All keys use NOTIFICATION_ prefix (CONVENTIONS §3).

# Required: Postgres DSN
NOTIFICATION_POSTGRES_DSN=postgres://notification_user:REPLACE_ME@localhost:5432/notification_db?sslmode=disable

# Optional: Postgres schema (default: "" = public schema).
# Set to "notification" when sharing one Aiven database across multiple services
# so each service is isolated by schema rather than by database.
# Only [a-zA-Z0-9_] characters are allowed.
# NOTIFICATION_DB_SCHEMA=notification

# Optional: Redis URL (omit to disable event consumer + use in-process rate limiter)
NOTIFICATION_REDIS_URL=redis://localhost:6379

# Server port (default: 8084)
NOTIFICATION_PORT=8084

# Log level: DEBUG|INFO|WARN|ERROR (default: INFO)
NOTIFICATION_LOG_LEVEL=DEBUG

# Environment: development|production|test (default: development)
NOTIFICATION_ENV=development

# ---------------------------------------------------------------------------
# Comms module (outbound messaging) — DORMANT BY DEFAULT.
# When NOTIFICATION_COMMS_ENABLED=false the service registers NO comms routes,
# NO S2S middleware, and does NOT subscribe comms.send_requested — it behaves
# exactly as the pure in-app inbox. Set to true only to activate the module.
# ---------------------------------------------------------------------------
NOTIFICATION_COMMS_ENABLED=false

# S2S shared bearer token for POST /v1/comms/send (header X-Service-Token).
# Required when comms is enabled; >= 24 chars in non-development.
# SECURITY: /v1/comms/send is an arbitrary-send primitive. The API gateway MUST
# NOT proxy /v1/comms/** from the public edge — it is internal/S2S only.
NOTIFICATION_S2S_TOKEN=REPLACE_ME

# Shared HMAC secret used to VERIFY inbound signed events (comms.send_requested).
# Required in non-development when comms is enabled. Same secret as publishers.
EVENT_HMAC_SECRET=REPLACE_ME

# Per-send timeout (default: 10s).
NOTIFICATION_COMMS_SEND_TIMEOUT=10s

# Email provider: smtp | ses | sendgrid | stub  (non-dev rejects 'stub').
NOTIFICATION_EMAIL_PROVIDER=stub
NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_SMTP_FROM=no-reply@coverones.example
NOTIFICATION_EMAIL_APP_BASE_URL=http://localhost:5500
# SMTP credentials — env-only, NEVER in DB / provider_settings.
NOTIFICATION_EMAIL_SMTP_USERNAME=REPLACE_ME
NOTIFICATION_EMAIL_SMTP_PASSWORD=REPLACE_ME

# SMS provider: stub | aws-sns | huawei | chunghwa  (non-dev rejects 'stub').
NOTIFICATION_SMS_PROVIDER=stub
NOTIFICATION_SMS_SENDER_ID=CoverOnes
NOTIFICATION_SMS_REGION=
# SMS credentials — env-only, NEVER in DB / provider_settings.
NOTIFICATION_SMS_API_KEY=REPLACE_ME
NOTIFICATION_SMS_API_SECRET=REPLACE_ME
